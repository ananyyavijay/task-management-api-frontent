# Base URL of the deployed Task Management API (FastAPI / Azure App Service).
# No trailing slash. Example production value:
#   NEXT_PUBLIC_API_BASE_URL=https://capstone-task-api.azurewebsites.net
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Name of the cookie used to persist the JWT access token in the browser.
NEXT_PUBLIC_AUTH_COOKIE_NAME=taskflow_token
